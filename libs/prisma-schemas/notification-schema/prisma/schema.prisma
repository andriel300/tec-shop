generator client {
  provider = "prisma-client-js"
  output   = "../../../../node_modules/.prisma/notification-client"
}

generator dbml {
  provider   = "prisma-dbml-generator"
  output     = "../../../../dbml"
  outputName = "notification-schema.dbml"
}

datasource db {
  provider = "mongodb"
  url      = env("NOTIFICATION_SERVICE_DB_URL")
}

model Notification {
  id         String        @id @default(auto()) @map("_id") @db.ObjectId
  targetType String
  targetId   String
  templateId String
  title      String
  message    String
  type       String
  isRead     Boolean       @default(false)
  metadata   Json?
  createdAt  DateTime      @default(now())
  deliveries DeliveryLog[]

  @@index([targetType, targetId, createdAt(sort: Desc)])
  @@index([targetType, targetId, isRead])
}

model DeliveryLog {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  notificationId String       @db.ObjectId
  channel        String       // EMAIL | PUSH
  status         String       // SENT | FAILED
  attemptCount   Int          @default(1)
  error          String?
  sentAt         DateTime?
  createdAt      DateTime     @default(now())
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@index([notificationId])
  @@index([channel, status])
}
