# =============================================================================
# TecShop Environment Variables - Production Example
# SECURITY NOTE: Use a secrets manager (Vault, AWS Secrets Manager, etc.)
# Never commit real secrets to version control
# =============================================================================

NODE_ENV=production

# =============================================================================
# Security (REQUIRED)
# =============================================================================
JWT_SECRET="production-jwt-secret-minimum-64-characters-for-security"
SERVICE_MASTER_SECRET="production-service-master-secret-minimum-64-characters"
OTP_SALT="production-otp-salt"

# =============================================================================
# Database URLs (MongoDB)
# =============================================================================
AUTH_SERVICE_DB_URL="mongodb+srv://user:pass@cluster.mongodb.net/tec-shop-auth"
USER_SERVICE_DB_URL="mongodb+srv://user:pass@cluster.mongodb.net/tec-shop-users"
SELLER_SERVICE_DB_URL="mongodb+srv://user:pass@cluster.mongodb.net/tec-shop-sellers"
PRODUCT_SERVICE_DB_URL="mongodb+srv://user:pass@cluster.mongodb.net/tec-shop-products"

# Use PostgreSQL for Order Service
ORDER_SERVICE_DB_URL="postgresql://user:pass@host:5432/tec-shop-order?sslmode=require&channel_binding=require"
CHATTING_SERVICE_DB_URL="mongodb+srv://user:pass@cluster.mongodb.net/tec-shop-chatting"
LOGGER_SERVICE_DB_URL="mongodb+srv://user:pass@cluster.mongodb.net/tec-shop-logger"
ANALYTICS_SERVICE_DB_URL="mongodb+srv://user:pass@cluster.mongodb.net/tec-shop-analytics"
NOTIFICATION_SERVICE_DB_URL="mongodb+srv://user:pass@cluster.mongodb.net/tec-shop-notification"

# =============================================================================
# Redis
# =============================================================================
REDIS_URL="rediss://user:pass@your-redis-host:6380"

# =============================================================================
# Kafka (Aiven — mTLS)
# Download certs from Aiven console and place in certs/kafka/
# =============================================================================
KAFKA_BROKER="kafka-tecshop-14902c27-proton-dbb8-tecshop.k.aivencloud.com:15835"
KAFKA_CLIENT_ID="tec-shop"

# To connect Aiven for production, download the 3 cert files from the Aiven console and place them at:
#  certs/kafka/ca.pem          ← CA Certificate
#  certs/kafka/service.cert    ← Access Certificate
#  certs/kafka/service.key     ← Access Key
KAFKA_SSL_CA_PATH="certs/kafka/ca.pem"
KAFKA_SSL_CERT_PATH="certs/kafka/service.cert"
KAFKA_SSL_KEY_PATH="certs/kafka/service.key"

# =============================================================================
# SMTP / Email
# =============================================================================
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=production-smtp-username
SMTP_PASS=production-smtp-password
SMTP_FROM=noreply@yourdomain.com
SMTP_SECURE=true

# =============================================================================
# Google OAuth
# =============================================================================
GOOGLE_CLIENT_ID="production-google-client-id"
GOOGLE_CLIENT_SECRET="production-google-client-secret"
GOOGLE_CALLBACK_URL="https://api.yourdomain.com/api/auth/google/callback"

# =============================================================================
# Stripe
# =============================================================================
STRIPE_SECRET_KEY="sk_live_your-stripe-live-secret-key"
STRIPE_WEBHOOK_SECRET="whsec_your-stripe-live-webhook-secret"

# =============================================================================
# ImageKit (CDN / File Uploads)
# =============================================================================
IMAGEKIT_URL_ENDPOINT="https://ik.imagekit.io/your-imagekit-id"
IMAGEKIT_PUBLIC_KEY="your-imagekit-public-key"
IMAGEKIT_PRIVATE_KEY="your-imagekit-private-key"

# =============================================================================
# Frontend URLs
# =============================================================================
FRONTEND_URL="https://yourdomain.com"
SELLER_UI_URL="https://seller.yourdomain.com"
NEXT_PUBLIC_BACKEND_URL="https://api.yourdomain.com"
NEXT_PUBLIC_API_URL="https://api.yourdomain.com"
NEXT_PUBLIC_WS_URL="api.yourdomain.com:6007"
NEXT_PUBLIC_LOGGER_WS_URL="api.yourdomain.com:6008"
NEXT_PUBLIC_NOTIFICATION_WS_URL="api.yourdomain.com:6012"

# =============================================================================
# CORS
# =============================================================================
CORS_ORIGINS="https://yourdomain.com,https://seller.yourdomain.com,https://admin.yourdomain.com"

# =============================================================================
# Microservice Hosts & Ports (use internal DNS in Kubernetes/Docker)
# =============================================================================
API_GATEWAY_HOST=api-gateway
API_GATEWAY_PORT=8080
API_GATEWAY_URL="https://api.yourdomain.com"

AUTH_SERVICE_HOST=auth-service
AUTH_SERVICE_PORT=6001

USER_SERVICE_HOST=user-service
USER_SERVICE_PORT=6002

SELLER_SERVICE_HOST=seller-service
SELLER_SERVICE_PORT=6003

PRODUCT_SERVICE_HOST=product-service
PRODUCT_SERVICE_PORT=6004

ORDER_SERVICE_HOST=order-service
ORDER_SERVICE_PORT=6005

ADMIN_SERVICE_HOST=admin-service
ADMIN_SERVICE_PORT=6006

CHATTING_SERVICE_HOST=chatting-service
CHATTING_SERVICE_PORT=6007
CHATTING_SERVICE_TCP_PORT=6010

LOGGER_SERVICE_HOST=logger-service
LOGGER_SERVICE_PORT=6008
LOGGER_SERVICE_TCP_PORT=6011

NOTIFICATION_SERVICE_HOST=notification-service
NOTIFICATION_SERVICE_PORT=6012
NOTIFICATION_SERVICE_TCP_PORT=6014

RECOMMENDATION_SERVICE_HOST=recommendation-service
RECOMMENDATION_SERVICE_PORT=6009

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=warn

# =============================================================================
# Admin Seeding (disable in production after initial setup)
# =============================================================================
# SEED_ADMIN_EMAIL="admin@yourdomain.com"
# SEED_ADMIN_PASSWORD="strong-admin-password"

# =============================================================================
# Sentry (error tracking)
# =============================================================================
SENTRY_DSN_BACKEND="your-sentry-dsn"
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE="1.0.0"
SENTRY_TRACES_SAMPLE_RATE=0.1
