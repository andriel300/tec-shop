# =============================================================================
# TecShop Environment Variables - Development Example
# Copy this file to .env and fill in your values
# =============================================================================

# Node Environment
NODE_ENV=development

# =============================================================================
# Security (REQUIRED - services will refuse to start without these)
# =============================================================================
JWT_SECRET="your-jwt-secret-minimum-32-characters-long"
SERVICE_MASTER_SECRET="your-service-master-secret-minimum-32-characters"
OTP_SALT="your-otp-salt-for-hashing"

# =============================================================================
# Database URLs (MongoDB)
# Connection pooling: add ?maxPoolSize=10&minPoolSize=2 to MongoDB Atlas URLs.
# Prisma uses the MongoDB driver pool; defaults are generous but untuned.
# Example Atlas URL with pool:
#   mongodb+srv://user:pass@cluster.mongodb.net/auth?maxPoolSize=10&minPoolSize=2
# =============================================================================
AUTH_SERVICE_DB_URL="mongodb://localhost:27017/tec-shop-auth"
USER_SERVICE_DB_URL="mongodb://localhost:27017/tec-shop-users"
SELLER_SERVICE_DB_URL="mongodb://localhost:27017/tec-shop-sellers"
PRODUCT_SERVICE_DB_URL="mongodb://localhost:27017/tec-shop-products"
# ORDER SERVICE IS NEON POSTGRESQL
# Add connection_limit and pool_timeout to avoid exhausting Neon's connection limit.
# Neon free tier: max 10 connections total. Set connection_limit per replica (e.g. 3 replicas → limit=3).
# Example: ORDER_SERVICE_DB_URL="postgresql://user:pass@ep-xxx.neon.tech/order?sslmode=require&connection_limit=3&pool_timeout=20"
ORDER_SERVICE_DB_URL="postgresql://neondb_owner:restofkeys"
CHATTING_SERVICE_DB_URL="mongodb://localhost:27017/tec-shop-chatting"
LOGGER_SERVICE_DB_URL="mongodb://localhost:27017/tec-shop-logger"
ANALYTICS_SERVICE_DB_URL="mongodb://localhost:27017/tec-shop-analytics"
NOTIFICATION_SERVICE_DB_URL="mongodb://localhost:27017/tec-shop-notifications"

# =============================================================================
# Redis
# =============================================================================
REDIS_URL="redis://localhost:6379"

# =============================================================================
# Kafka / RedPanda
# =============================================================================
# Local development (no authentication):
KAFKA_BROKER="localhost:9092"
KAFKA_CLIENT_ID="tec-shop"

# SSL is auto-detected: disabled for localhost/127.0.0.1, enabled for remote brokers
# To override: KAFKA_SSL=true or KAFKA_SSL=false
# KAFKA_SSL=false

# Cloud Kafka with SCRAM-SHA-256 (RedPanda, Confluent, etc.):
# KAFKA_BROKER="your-kafka-broker-address:9092"
# KAFKA_USERNAME="your-kafka-username"
# KAFKA_PASSWORD="your-kafka-password"

# Legacy RedPanda variables (backward compatibility - deprecated)
# REDPANDA_BROKER="your-redpanda-broker-address:9092"
# REDPANDA_USERNAME="your-redpanda-username"
# REDPANDA_PASSWORD="your-redpanda-password"

# Silence KafkaJS v2 partitioner migration warning (cosmetic — safe to set)
KAFKAJS_NO_PARTITIONER_WARNING=1

# =============================================================================
# SMTP / Email
# =============================================================================
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@yourapp.com
SMTP_SECURE=false

# =============================================================================
# Google OAuth
# =============================================================================
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:8080/api/auth/google/callback"

# =============================================================================
# Stripe
# =============================================================================
STRIPE_SECRET_KEY="sk_test_your-stripe-secret-key"
STRIPE_WEBHOOK_SECRET="whsec_your-stripe-webhook-secret"

# =============================================================================
# ImageKit (CDN / File Uploads)
# =============================================================================
IMAGEKIT_URL_ENDPOINT="https://ik.imagekit.io/your-imagekit-id"
IMAGEKIT_PUBLIC_KEY="your-imagekit-public-key"
IMAGEKIT_PRIVATE_KEY="your-imagekit-private-key"
# Exposed to seller-ui client-side via next.config.js env mapping.
# If set here directly it overrides the mapping — value must match IMAGEKIT_URL_ENDPOINT.
NEXT_PUBLIC_IMAGEKIT_URL_ENDPOINT="https://ik.imagekit.io/your-imagekit-id"

# =============================================================================
# Frontend URLs
# =============================================================================
FRONTEND_URL="http://localhost:3000"
SELLER_UI_URL="http://localhost:3001"
NEXT_PUBLIC_SELLER_SERVER_URI="http://localhost:3001"
NEXT_PUBLIC_MARKETPLACE_URL="http://localhost:3000"
NEXT_PUBLIC_USER_UI_URL="http://localhost:3000"
NEXT_PUBLIC_BACKEND_URL="http://localhost:8080"
# Must include the /api prefix — the axios client uses this as baseURL directly.
# Wrong:   http://localhost:8080      (all requests 404)
# Correct: http://localhost:8080/api
NEXT_PUBLIC_API_URL="http://localhost:8080/api"
NEXT_PUBLIC_WS_URL="localhost:6007"
NEXT_PUBLIC_LOGGER_WS_URL="localhost:6008"
NEXT_PUBLIC_NOTIFICATION_WS_URL="localhost:6012"

# =============================================================================
# CORS
# =============================================================================
CORS_ORIGINS="http://localhost:3000,http://localhost:3001,http://localhost:3002"

# =============================================================================
# Microservice Hosts & Ports
# =============================================================================
API_GATEWAY_HOST=localhost
API_GATEWAY_PORT=8080
API_GATEWAY_URL="http://localhost:8080"

AUTH_SERVICE_HOST=localhost
AUTH_SERVICE_PORT=6001

USER_SERVICE_HOST=localhost
USER_SERVICE_PORT=6002

SELLER_SERVICE_HOST=localhost
SELLER_SERVICE_PORT=6003

PRODUCT_SERVICE_HOST=localhost
PRODUCT_SERVICE_PORT=6004

ORDER_SERVICE_HOST=localhost
ORDER_SERVICE_PORT=6005

ADMIN_SERVICE_HOST=localhost
ADMIN_SERVICE_PORT=6006

CHATTING_SERVICE_HOST=localhost
CHATTING_SERVICE_PORT=6007
CHATTING_SERVICE_TCP_PORT=6010

LOGGER_SERVICE_HOST=localhost
LOGGER_SERVICE_PORT=6008
LOGGER_SERVICE_TCP_PORT=6011

RECOMMENDATION_SERVICE_HOST=localhost
RECOMMENDATION_SERVICE_PORT=6009

NOTIFICATION_SERVICE_HOST=localhost
NOTIFICATION_SERVICE_PORT=6014
NOTIFICATION_SERVICE_TCP_PORT=6014

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=debug

# =============================================================================
# Admin Seeding (optional - used by seed scripts)
# =============================================================================
SEED_ADMIN_EMAIL="admin@yourapp.com"
SEED_ADMIN_PASSWORD="your-admin-seed-password"

# =============================================================================
# Sentry (optional - error tracking)
# =============================================================================
# SENTRY_DSN_BACKEND="your-sentry-dsn"
# SENTRY_ENVIRONMENT=development
# SENTRY_RELEASE="1.0.0"
# SENTRY_TRACES_SAMPLE_RATE=0.1

# =============================================================================
# Metrics HTTP ports (hybrid app HTTP listener for Prometheus scraping)
# =============================================================================
AUTH_METRICS_PORT=9001
USER_METRICS_PORT=9002
SELLER_METRICS_PORT=9003
PRODUCT_METRICS_PORT=9004
ORDER_METRICS_PORT=9005
ADMIN_METRICS_PORT=9006
KAFKA_SERVICE_METRICS_PORT=9009
RECOMMENDATION_METRICS_PORT=9010

# =============================================================================
# Distributed Tracing (optional - leave unset to disable)
# =============================================================================
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
