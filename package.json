{
  "name": "@tec-shop/source",
  "version": "0.0.0",
  "license": "MIT",
  "packageManager": "pnpm@10.32.0",
  "scripts": {
    "dev": "npx nx run-many --target=serve --all",
    "dev:ui:user": "PORT=3000 npx nx dev user-ui",
    "dev:ui:seller": "PORT=3001 npx nx dev seller-ui",
    "dev:ui:admin": "PORT=3002 npx nx dev admin-ui",

    "build": "npx nx run-many --target=build --all",
    "build:affected": "npx nx affected --target=build",
    "lint": "npx nx run-many --target=lint --all",
    "lint:affected": "npx nx affected --target=lint",
    "typecheck": "npx nx run-many --target=typecheck --all",
    "typecheck:affected": "npx nx affected --target=typecheck",
    "test": "npx nx run-many --target=test --all",
    "test:affected": "npx nx affected --target=test",
    "ci": "npx nx affected -t build,lint,typecheck,test",

    "infra:up": "docker compose -f infrastructure/docker/docker-compose.infra.yml up -d",
    "infra:down": "docker compose -f infrastructure/docker/docker-compose.infra.yml down",
    "infra:restart": "pnpm infra:down && pnpm infra:up",
    "infra:logs": "docker compose -f infrastructure/docker/docker-compose.infra.yml logs -f",

    "stack:up": "./infrastructure/scripts/local-dev-up.sh",
    "stack:up:build": "./infrastructure/scripts/local-dev-up.sh --build",
    "stack:down": "./infrastructure/scripts/local-dev-up.sh --down",
    "stack:logs": "docker compose -f infrastructure/docker/docker-compose.dev.yml logs -f",

    "k8s:build": "./infrastructure/scripts/build-and-load.sh",
    "k8s:secrets": "./infrastructure/scripts/create-k8s-secrets.sh local",
    "k8s:deploy": "./infrastructure/scripts/deploy.sh local",
    "k8s:deploy:dev": "./infrastructure/scripts/deploy.sh dev",
    "k8s:deploy:prod": "./infrastructure/scripts/deploy.sh prod",
    "k8s:status": "kubectl get pods -n tec-shop",
    "k8s:logs": "kubectl logs -n tec-shop -l app.kubernetes.io/part-of=tec-shop --prefix --follow",
    "k8s:teardown": "helm uninstall tec-shop -n tec-shop",

    "prisma:generate": "npx nx run @tec-shop/auth-schema:generate-types && npx nx run @tec-shop/user-schema:generate-types && npx nx run @tec-shop/seller-schema:generate-types && npx nx run @tec-shop/product-schema:generate-types && npx nx run @tec-shop/analytics-schema:generate-types && npx nx run @tec-shop/order-schema:generate-types && npx nx run @tec-shop/chatting-schema:generate-types && npx nx run @tec-shop/logger-schema:generate-types && npx nx run @tec-shop/notification-schema:generate-types",
    "prisma:push": "npx nx run-many --target=db-push --projects=@tec-shop/auth-schema,@tec-shop/user-schema,@tec-shop/seller-schema,@tec-shop/product-schema,@tec-shop/analytics-schema,@tec-shop/order-schema,@tec-shop/chatting-schema,@tec-shop/logger-schema,@tec-shop/notification-schema",
    "prisma:format": "npx nx run-many --target=format --projects=@tec-shop/auth-schema,@tec-shop/user-schema,@tec-shop/seller-schema,@tec-shop/product-schema,@tec-shop/analytics-schema,@tec-shop/order-schema",
    "prisma:studio": "npx nx run-many --target=studio --projects=@tec-shop/auth-schema,@tec-shop/user-schema,@tec-shop/seller-schema,@tec-shop/product-schema,@tec-shop/analytics-schema --parallel=5",

    "seed": "pnpm seed:brands && pnpm seed:categories && pnpm seed:products",
    "seed:brands": "npx tsx apps/product-service/src/scripts/seed-brands.ts",
    "seed:categories": "npx tsx apps/product-service/src/scripts/seed-categories.ts",
    "seed:products": "npx tsx apps/product-service/src/scripts/seed-products.ts",
    "seed:admin": "npx tsx apps/admin-service/src/scripts/seed-admin.ts",
    "seed:recommendations": "npx tsx apps/recommendation-service/src/scripts/seed-recommendation-data.ts",

    "certs:generate": "./generate-certs.sh --all",
    "certs:clean": "./generate-certs.sh --clean",

    "db:create-ttl-indexes": "node infrastructure/scripts/create-ttl-indexes.js",

    "load-test:baseline": "bash load-testing/run-tests.sh --baseline",
    "load-test:stress": "bash load-testing/run-tests.sh --stress",
    "load-test:spike": "bash load-testing/run-tests.sh --spike",
    "load-test:soak": "bash load-testing/run-tests.sh --soak",

    "postinstall": "patch-package"
  },
  "private": true,
