{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "types": ["node"],
    "rootDir": "src",
    "tsBuildInfoFile": "dist/tsconfig.app.tsbuildinfo",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "target": "es2021",
    "composite": true
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "out-tsc",
    "dist",
    "jest.config.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "eslint.config.js",
    "eslint.config.cjs",
    "eslint.config.mjs"
  ],
  "references": [
    {
      "path": "../../libs/shared/redis-client/tsconfig.lib.json"
    },
    {
      "path": "../../libs/shared/dto/tsconfig.lib.json"
    },
    {
      "path": "../../libs/prisma-clients/notification-client/tsconfig.lib.json"
    },
    {
      "path": "../../libs/shared/ws-auth/tsconfig.lib.json"
    },
    {
      "path": "../../libs/shared/tracing/tsconfig.lib.json"
    },
    {
      "path": "../../libs/shared/kafka-events/tsconfig.lib.json"
    },
    {
      "path": "../../libs/shared/sentry/tsconfig.lib.json"
    },
    {
      "path": "../../libs/shared/metrics/tsconfig.lib.json"
    }
  ]
}
