{
  "name": "@tec-shop/mono-api",
  "version": "1.0.0",
  "private": true,
  "nx": {
    "name": "mono-api",
    "targets": {
      "build": {
        "executor": "nx:run-commands",
        "options": {
          "command": "webpack-cli build",
          "args": ["--node-env=production"],
          "cwd": "apps/mono-api"
        },
        "configurations": {
          "development": {
            "args": ["--node-env=development"]
          }
        }
      },
      "prune-lockfile": {
        "dependsOn": ["build"],
        "cache": true,
        "executor": "@nx/js:prune-lockfile",
        "outputs": ["{workspaceRoot}/apps/mono-api/dist/package.json", "{workspaceRoot}/apps/mono-api/dist/pnpm-lock.yaml"],
        "options": { "buildTarget": "build" }
      },
      "copy-workspace-modules": {
        "dependsOn": ["build"],
        "cache": true,
        "outputs": ["{workspaceRoot}/apps/mono-api/dist/workspace_modules"],
        "executor": "@nx/js:copy-workspace-modules",
        "options": { "buildTarget": "build" }
      },
      "prune": {
        "dependsOn": ["prune-lockfile", "copy-workspace-modules"],
        "executor": "nx:noop"
      },
      "serve": {
        "continuous": true,
        "executor": "@nx/js:node",
        "defaultConfiguration": "development",
        "dependsOn": ["build"],
        "options": { "buildTarget": "mono-api:build", "runBuildTargetDependencies": false },
        "configurations": {
          "development": { "buildTarget": "mono-api:build:development" },
          "production": { "buildTarget": "mono-api:build:production" }
        }
      },
      "typecheck": {
        "executor": "nx:run-commands",
        "options": {
          "command": "tsc --noEmit",
          "cwd": "apps/mono-api"
        }
      },
      "test": {
        "options": { "passWithNoTests": true }
      }
    },
    "tags": ["scope:backend", "type:app"]
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/event-emitter": "^3.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/throttler": "^6.0.0",
    "@nest-lab/throttler-storage-redis": "^0.0.4",
    "@tec-shop/mono-client": "workspace:*",
    "@tec-shop/redis-client": "workspace:*",
    "@tec-shop/metrics": "workspace:*",
    "@tec-shop/dto": "workspace:*",
    "@tec-shop/interceptor": "workspace:*",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-google-oauth20": "^2.0.0",
    "class-validator": "^0.14.0",
    "class-transformer": "^0.5.1",
    "cookie-parser": "^1.4.6",
    "argon2": "^0.41.0",
    "bcrypt": "^5.1.1",
    "zod": "^3.23.0",
    "nestjs-pino": "^4.0.0",
    "pino": "^9.0.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.0.0",
    "@types/cookie-parser": "^1.4.7",
    "@types/passport-jwt": "^4.0.0",
    "@types/passport-google-oauth20": "^2.0.0",
    "@types/bcrypt": "^5.0.0"
  }
}
