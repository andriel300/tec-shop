      "title": "CPU Usage Rate per Service",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(process_cpu_seconds_total[5m])",
          "legendFormat": "{{ job }}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 54 },
      "id": 70,
      "title": "Node.js Runtime — All Services",
