          "expr": "nodejs_heap_size_used_bytes",
          "legendFormat": "{{ job }}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Resident Set Size (RSS) — total memory allocated by the OS for the process.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "showPoints": "never" },
          "unit": "bytes"
        },
        "overrides": []
