# EXAMPLE SECRETS FILE - DO NOT COMMIT REAL SECRETS
# Copy this file to app-secrets.yaml and fill in real values
# The real app-secrets.yaml is .gitignored
#
# To create the secret in Kubernetes:
#   kubectl apply -f infrastructure/k8s/secrets/app-secrets.yaml
#
# To encode values for Kubernetes secrets, use:
#   echo -n 'your-secret-value' | base64
#
# TODO: Consider using External Secrets Operator (ESO) with AWS Secrets Manager,
#       GCP Secret Manager, or HashiCorp Vault for production secret management.

apiVersion: v1
kind: Secret
metadata:
  name: tec-shop-secrets
  namespace: tec-shop
  labels:
    app.kubernetes.io/part-of: tec-shop
type: Opaque
data:
  # JWT_SECRET - must be at least 32 characters, base64 encoded
  # Example: echo -n 'your-32-char-minimum-jwt-secret-here' | base64
  JWT_SECRET: "REPLACE_WITH_BASE64_ENCODED_JWT_SECRET"

  # SERVICE_MASTER_SECRET - for HMAC inter-service authentication, base64 encoded
  SERVICE_MASTER_SECRET: "REPLACE_WITH_BASE64_ENCODED_SERVICE_MASTER_SECRET"

  # MongoDB connection string, base64 encoded
  # Example: mongodb://admin:password@mongodb:27017/
  DATABASE_URL: "REPLACE_WITH_BASE64_ENCODED_MONGO_URL"

  # Redis URL, base64 encoded
  # Example: redis://redis:6379
  REDIS_URL: "REPLACE_WITH_BASE64_ENCODED_REDIS_URL"

  # ImageKit private key (backend only), base64 encoded
  IMAGEKIT_PRIVATE_KEY: "REPLACE_WITH_BASE64_ENCODED_IMAGEKIT_PRIVATE_KEY"

  # ImageKit public key, base64 encoded
  IMAGEKIT_PUBLIC_KEY: "REPLACE_WITH_BASE64_ENCODED_IMAGEKIT_PUBLIC_KEY"

  # Email service credentials (for OTP and notifications), base64 encoded
  # TODO: Add SMTP or transactional email provider credentials
  EMAIL_USER: "REPLACE_WITH_BASE64_ENCODED_EMAIL_USER"
  EMAIL_PASS: "REPLACE_WITH_BASE64_ENCODED_EMAIL_PASS"

  # Stripe credentials (for payment processing), base64 encoded
  # TODO: Add Stripe keys when payment service is implemented
  STRIPE_SECRET_KEY: "REPLACE_WITH_BASE64_ENCODED_STRIPE_SECRET_KEY"
  STRIPE_WEBHOOK_SECRET: "REPLACE_WITH_BASE64_ENCODED_STRIPE_WEBHOOK_SECRET"

  # MongoDB credentials, base64 encoded
  MONGO_USERNAME: "REPLACE_WITH_BASE64_ENCODED_MONGO_USERNAME"
  MONGO_PASSWORD: "REPLACE_WITH_BASE64_ENCODED_MONGO_PASSWORD"
